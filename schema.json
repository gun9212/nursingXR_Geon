{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "NursingCare_RAG_FAISS_V3",
    "type": "object",
    "required": [
        "document_id",
        "source_metadata",
        "chunks"
    ],
    "properties": {
        "document_id": {
            "type": "string"
        },
        "source_metadata": {
            "type": "object",
            "required": [
                "source_name",
                "source_url",
                "title",
                "crawled_at"
            ],
            "properties": {
                "source_name": {
                    "type": "string",
                    "description": "데이터 출처 (예: EuropePMC, PubMed, Wikipedia)"
                },
                "source_url": {
                    "type": "string",
                    "description": "논문 접속 URL 또는 원문 링크"
                },
                "title": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "문서 제목"
                },
                "original_language": {
                    "type": "string",
                    "enum": [
                        "ko",
                        "en",
                        "unknown"
                    ]
                },
                "doi": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "crawled_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "extra": {
                    "type": "object",
                    "description": "추가 메타데이터 (PMCID, 저자 등)"
                }
            }
        },
        "document_summary": {
            "type": [
                "string",
                "null"
            ],
            "description": "문서 전체의 핵심 내용 요약"
        },
        "chunks": {
            "type": "array",
            "description": "사전 분할된 문서 블록 리스트 (Pre-chunking)",
            "items": {
                "type": "object",
                "required": [
                    "chunk_id",
                    "search_keywords",
                    "raw_text",
                    "selection_reason_ko"
                ],
                "properties": {
                    "chunk_id": {
                        "type": "string"
                    },
                    "search_keywords": {
                        "type": "array",
                        "description": "하이브리드 검색을 위한 핵심 질환명, 고유 명사 등 키워드",
                        "items": {
                            "type": "string"
                        }
                    },
                    "raw_text": {
                        "type": "string",
                        "description": "문맥 손실 없이 원문 100% 보존된 파싱 마크다운 데이터"
                    },
                    "selection_reason_ko": {
                        "type": "string",
                        "description": "이 문서를 선택한 이유 및 핵심 내용 3줄 요약 (LLM 생성, 벡터 임베딩 기준)"
                    }
                }
            }
        }
    }
}